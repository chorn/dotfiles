# https://ghostty.org/docs/config
# vim: set ft=toml sw=2 ts=2 expandtab:
# ghostty +show-config --changes-only

auto-update = off
background = #000000
clipboard-read = allow
clipboard-trim-trailing-spaces = true
clipboard-write = allow
command = zsh
cursor-color = #FFFF00
cursor-style = block
font-family = VictorMono Nerd Font Mono
font-feature = -calt, -liga, -dlig
font-synthetic-style = false
font-size = 16
font-thicken = true
link-previews = true
link-url = true
macos-auto-secure-input = false
macos-icon = retro
macos-shortcuts = allow
macos-titlebar-style = tabs
mouse-reporting = false
selection-clear-on-copy = true
selection-clear-on-typing = true
shell-integration-features = false
split-inherit-working-directory = true
tab-inherit-working-directory = true
theme = Tomorrow Night
title = " "
title-report = false
working-directory = inherit
window-show-tab-bar = always
window-subtitle = working-directory
window-theme = ghostty
working-directory = home
unfocused-split-opacity = 1.0
