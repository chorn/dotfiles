#!/usr/bin/env bash

set -Eeuo pipefail

#-----------------------------------------------------------------------------
_yup() {
  local _what=$1
  [[ -n "$_what" ]] || return 1
  which "$_what" >&/dev/null || return 0
  local _ywhat=_yup_${_what}
  echo ">>> $_what"
  "${_ywhat}"
}
#-----------------------------------------------------------------------------
_yup_vim() {
  vim --not-a-term +PlugUpgrade +PlugUpdate +PlugClean +qall
}
#-----------------------------------------------------------------------------
_yup_zi() {
  zi self-update
  zi update --all --parallel
  zi compinit
  zi zstatus
}
#-----------------------------------------------------------------------------
_yup_brew() {
  brew doctor || true
  brew update
  brew outdated
  brew upgrade
  brew cleanup --prune=all --scrub
}
#-----------------------------------------------------------------------------
_yup_mise() {
  mise self-update --yes
  mise doctor >&/dev/null
  mise install --yes
  mise upgrade --yes --bump
}
#-----------------------------------------------------------------------------
yup() {
  local -a _what=("$@")
  [[ "${#_what[@]}" -gt 0 ]] || _what=(brew zi mise vim)
  for _cmd in "${_what[@]}"; do
    _yup "$_cmd"
  done
}
#-----------------------------------------------------------------------------
yup $@
